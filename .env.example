# Jira Cloud Configuration (required for live Jira sync)
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_jira_api_token

# Team-specific JQL is in config/team-jql.json (TO, CE, KTC projects)
# JIRA_PROJECT_KEYS is fallback when team-jql.json is empty
JIRA_PROJECT_KEYS=TO,CE,KTC

# Optional: Target release date for display
TARGET_RELEASE_DATE=2026-04-07

# Demo mode: If JIRA_BASE_URL or JIRA_API_TOKEN is empty, app uses demo data
